  "animations": {
    "duration": {
      "instant": "0ms",
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms",
      "slower": "700ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "inOut": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.175, 0.885, 0.32, 1.275)",
      "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "patterns": [
      {
        "name": "fade-up",
        "description": "Scroll reveal: elements fade in and slide up 40px",
        "duration": "800ms",
        "easing": "power3.out (GSAP)",
        "trigger": "scrollTrigger, top 85%",
        "properties": ["opacity 0→1", "y 40→0"]
      },
      {
        "name": "hover-lift",
        "description": "Cards lift with gold glow shadow on hover",
        "duration": "250ms",
        "easing": "ease-in-out",
        "properties": ["translateY 0→-4px", "shadow sm→accent"]
      },
      {
        "name": "hover-scale",
        "description": "Interactive elements scale slightly on hover",
        "duration": "200ms",
        "easing": "ease-out",
        "properties": ["scale 1→1.02"]
      },
      {
        "name": "gold-pulse",
        "description": "Accent elements pulse with gold glow",
        "duration": "2000ms",
        "easing": "ease-in-out",
        "properties": ["box-shadow goldSubtle→gold→goldSubtle", "infinite"]
      },
      {
        "name": "stagger-children",
        "description": "Sequential reveal of child elements",
        "duration": "500ms",
        "stagger": "100ms",
        "easing": "power3.out (GSAP)",
        "properties": ["opacity 0→1", "y 20→0"]
      }
    ],
