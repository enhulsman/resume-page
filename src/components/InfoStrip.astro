---
import site from "../config/site";
import IconEmail from "./icons/IconEmail.astro";
import IconGitHub from "./icons/IconGitHub.astro";
import IconLinkedIn from "./icons/IconLinkedIn.astro";
import IconDocument from "./icons/IconDocument.astro";

const keySkills = ['Python', 'Rust', 'Docker', 'K8s', 'Pega', 'CI/CD'];
---

<div class="py-8 md:py-10">
  <div class="mx-auto w-full max-w-7xl px-6 md:px-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      <!-- Role + Status -->
      <div>
        <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-theme-muted block mb-1.5">Role</span>
        <p class="text-sm md:text-base text-theme-primary font-medium">{site.role}</p>
        <p class="text-xs md:text-sm text-theme-muted mt-0.5">@ {site.company}</p>
      </div>

      <!-- Location -->
      <div>
        <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-theme-muted block mb-1.5">Based in</span>
        <p class="text-sm md:text-base text-theme-primary font-medium inline-flex items-center gap-1.5">
          {site.location}
          <img
            src="/utrecht_province_fat_outline_black.png"
            alt="Utrecht Province"
            width="20"
            height="20"
            class="w-5 h-5 ml-1 province-for-light"
          />
          <img
            src="/utrecht_province_fat_outline_white.png"
            alt="Utrecht Province"
            width="20"
            height="20"
            class="w-5 h-5 ml-1 province-for-dark"
          />
        </p>
      </div>

      <!-- Key Skills -->
      <div>
        <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-theme-muted block mb-1.5">Stack</span>
        <div class="flex flex-wrap gap-1.5">
          {keySkills.map(skill => (
            <span class="font-mono text-xs px-2 py-0.5 rounded border border-[var(--color-border-primary)] text-theme-secondary">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-theme-muted block mb-1.5">Links</span>
        <div class="flex items-center gap-2.5">
          <a href="/resume" class="flex items-center gap-1.5 text-xs md:text-sm text-theme-secondary hover:text-theme-accent transition-colors font-medium">
            <IconDocument class="w-4 h-4" />
            Resume
          </a>
          <span class="text-theme-muted">·</span>
          <a href={`mailto:${site.social.email}`} class="text-theme-secondary hover:text-theme-accent transition-colors" title="Email">
            <IconEmail class="w-4 h-4" />
          </a>
          <a href={site.social.GitHub} target="_blank" rel="noopener noreferrer" class="text-theme-secondary hover:text-theme-accent transition-colors" title="GitHub">
            <IconGitHub class="w-4 h-4" />
          </a>
          <a href={site.social.LinkedIn} target="_blank" rel="noopener noreferrer" class="text-theme-secondary hover:text-theme-accent transition-colors" title="LinkedIn">
            <IconLinkedIn class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* Dark theme (default): show white outline on dark bg */
  img.province-for-light { display: none; }
  img.province-for-dark { display: inline-block; }

  /* Light theme: show black outline on light bg */
  [data-theme="light"] img.province-for-light { display: inline-block; }
  [data-theme="light"] img.province-for-dark { display: none; }
</style>
