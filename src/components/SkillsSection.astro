---
import { skillCategories, spokenLanguages } from "../config/resume";

// Flatten all skills for marquee rows
const allSkills = skillCategories.flatMap(cat => cat.items);
const row1 = allSkills.slice(0, Math.ceil(allSkills.length / 2));
const row2 = allSkills.slice(Math.ceil(allSkills.length / 2));

// Add spoken languages as bonus items
const languageTags = spokenLanguages.map(l => `${l.name} (${l.level})`);
---

<section id="skills" class="relative py-24 md:py-32 overflow-hidden">
  <div class="mx-auto w-full max-w-7xl px-6 md:px-12">
    <!-- Section label -->
    <div class="mb-16" data-reveal>
      <span class="font-mono text-xs tracking-[0.3em] uppercase text-theme-accent">// Skills</span>
      <h2 class="mt-2 font-display text-3xl md:text-5xl font-bold text-theme-primary tracking-tight">
        What I work with
      </h2>
    </div>
  </div>

  <!-- Marquee row 1 (left to right) -->
  <div class="relative mb-4">
    <div class="marquee-fade-left" aria-hidden="true"></div>
    <div class="marquee-fade-right" aria-hidden="true"></div>
    <div class="marquee-track" style="animation: marquee 35s linear infinite;">
      {[...row1, ...row1, ...row1, ...row1].map(skill => (
        <span class="marquee-item">{skill}</span>
      ))}
    </div>
  </div>

  <!-- Marquee row 2 (right to left) -->
  <div class="relative mb-4">
    <div class="marquee-fade-left" aria-hidden="true"></div>
    <div class="marquee-fade-right" aria-hidden="true"></div>
    <div class="marquee-track" style="animation: marquee-reverse 40s linear infinite;">
      {[...row2, ...languageTags, ...row2, ...languageTags, ...row2, ...languageTags, ...row2, ...languageTags].map(skill => (
        <span class="marquee-item">{skill}</span>
      ))}
    </div>
  </div>

  <!-- Skill categories grid -->
  <div class="mx-auto w-full max-w-7xl px-6 md:px-12 mt-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {skillCategories.map(category => (
        <div class="rounded-xl border border-[var(--color-border-primary)] bg-[var(--color-bg-secondary)] p-5" data-reveal>
          <h3 class="font-mono text-xs tracking-[0.2em] uppercase text-theme-accent mb-4">{category.label}</h3>
          <div class="flex flex-wrap gap-2">
            {category.items.map(item => (
              <span class="font-mono text-xs px-2.5 py-1 rounded-md border border-[var(--color-border-primary)] text-theme-secondary bg-[var(--color-bg-primary)] hover:border-[var(--color-accent-border)] hover:text-theme-accent transition-colors duration-200">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Spoken languages -->
    <div class="mt-8 flex items-center gap-4 justify-center" data-reveal>
      <span class="font-mono text-xs text-theme-muted tracking-wider uppercase">Languages:</span>
      {spokenLanguages.map((lang, i) => (
        <span class="text-sm text-theme-secondary">
          {lang.name} <span class="text-theme-muted">({lang.level})</span>
          {i < spokenLanguages.length - 1 && <span class="text-theme-muted ml-4">·</span>}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    will-change: transform;
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border-primary);
    background-color: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    font-family: var(--font-mono, monospace);
    font-size: 0.8125rem;
    letter-spacing: 0.025em;
    transition: border-color 0.2s, color 0.2s;
  }

  .marquee-item:hover {
    border-color: var(--color-accent-border);
    color: var(--color-accent-primary);
  }

  .marquee-fade-left,
  .marquee-fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 4rem;
    z-index: 10;
    pointer-events: none;
  }

  .marquee-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--color-bg-primary), transparent);
  }

  .marquee-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--color-bg-primary), transparent);
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @keyframes marquee-reverse {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none !important;
    }
  }
</style>
