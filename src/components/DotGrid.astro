---
// Dot grid + warmth background
// Canvas mount (#page-dots-mount) and reduced-motion fallback are first.
// Warmth hotspot wrapper (#dot-grid-wrapper) is second — paints on top of
// the transparent canvas by DOM order. z-index 0 vs 1 makes this explicit.

interface Props { hasHero?: boolean; }
const { hasHero = false } = Astro.props;

// Warmth hotspot positions — each is an individual div with a single radial gradient
const hotspots = [
  { top: '12%', right: '-3%', size: 750, opacity: 0.10, delay: 0 },
  { top: '38%', left: '-5%', size: 650, opacity: 0.08, delay: 2 },
  { top: '72%', left: '15%', size: 700, opacity: 0.09, delay: 4 },
  { top: '90%', right: '-2%', size: 600, opacity: 0.07, delay: 6 },
];
---

<!-- Canvas mount point — z-index:0, canvas is appended here by page-dots.ts -->
<div id="page-dots-mount" class="fixed inset-0 pointer-events-none" style="z-index:0;" aria-hidden="true"></div>

<!-- Reduced-motion fallback — static CSS dot grid, hidden until JS confirms canvas is unavailable -->
<div id="dot-grid-fallback" class="hidden fixed inset-0 pointer-events-none dot-grid-pattern" aria-hidden="true"></div>

<!-- Warmth hotspot wrapper — z-index:1, paints above the transparent canvas -->
<div id="dot-grid-wrapper" class="pointer-events-none absolute inset-x-0 top-0 overflow-hidden" style="z-index:1;" aria-hidden="true">
  <div class={`absolute left-0 right-0 bottom-0 ${hasHero ? 'warmth-below-hero' : 'warmth-full'}`}>
    {hotspots.map((spot) => (
      <div
        class="dot-grid-hotspot absolute rounded-full"
        style={`
          ${spot.top ? `top: ${spot.top};` : ''}
          ${spot.right ? `right: ${spot.right};` : ''}
          ${spot.left ? `left: ${spot.left};` : ''}
          width: ${spot.size}px;
          height: ${spot.size}px;
          opacity: ${spot.opacity};
          animation-delay: ${spot.delay}s;
        `}
      />
    ))}
  </div>
</div>

<style is:global>
  /* Used by the reduced-motion fallback only */
  .dot-grid-pattern {
    background-image: radial-gradient(var(--color-accent-primary) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.15;
    transition: opacity 0.3s ease;
  }

  [data-theme="light"] .dot-grid-pattern {
    opacity: 0.22;
  }

  /* Warmth positioning */
  .warmth-below-hero {
    top: 100vh;
    top: 100dvh;
  }

  .warmth-full {
    top: 0;
  }

  /* Individual hotspot — single smooth radial gradient, gentle drift */
  .dot-grid-hotspot {
    background: radial-gradient(
      circle,
      rgba(212, 160, 48, 0.6) 0%,
      rgba(212, 160, 48, 0.3) 25%,
      rgba(212, 160, 48, 0.1) 50%,
      transparent 70%
    );
    animation: hotspot-drift 30s ease-in-out infinite alternate;
  }

  [data-theme="light"] .dot-grid-hotspot {
    background: radial-gradient(
      circle,
      rgba(184, 136, 42, 0.5) 0%,
      rgba(184, 136, 42, 0.25) 25%,
      rgba(184, 136, 42, 0.08) 50%,
      transparent 70%
    );
  }

  @keyframes hotspot-drift {
    0%   { transform: translate(0, 0); }
    100% { transform: translate(40px, 25px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot-grid-hotspot { animation: none; }
  }
</style>

<!-- Height tracking for warmth hotspot wrapper (percentage positions need full page height) -->
<script>
  const wrapper = document.getElementById('dot-grid-wrapper');
  if (wrapper) {
    function setGridHeight() {
      wrapper.style.height = document.documentElement.scrollHeight + 'px';
    }
    setGridHeight();
    const ro = new ResizeObserver(setGridHeight);
    ro.observe(document.documentElement);
    setTimeout(setGridHeight, 3000);
  }
</script>

<script>
  import { initPageDots } from '../scripts/page-dots';

  const result = initPageDots();
  if (!result) {
    // Canvas unavailable (reduced-motion or no canvas support) — show CSS fallback
    document.getElementById('dot-grid-fallback')?.classList.remove('hidden');
  }
</script>
