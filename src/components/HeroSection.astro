---
import site from "../config/site";

const roles = [site.role, 'Infrastructure Engineer', 'Linux Enthusiast', 'Automation Builder'];
const firstName = site.name.split(' ')[0];
const lastName = site.name.split(' ').slice(1).join(' ');
---

<section id="hero" class="relative flex min-h-dvh items-end overflow-hidden pb-24 md:items-center md:pb-0">
  <!-- Grain texture -->
  <div
    class="absolute inset-0 opacity-[0.035] pointer-events-none"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.9%27 numOctaves=%274%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 128px 128px;"
    aria-hidden="true"
  ></div>

  <!-- Vignette -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at center, transparent 40%, var(--color-bg-primary) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Warm ambient glow behind name -->
  <div class="absolute inset-0 pointer-events-none hero-initial-hidden hero-glow-layer" aria-hidden="true" data-hero-glow></div>

  <!-- Orbiting dots -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true" data-hero-orbits>
    <div class="relative w-[600px] h-[600px] md:w-[800px] md:h-[800px]" style="animation: orbit-spin 30s linear infinite;">
      <div class="absolute top-0 left-1/2 w-1.5 h-1.5 -translate-x-1/2 rounded-full bg-[var(--color-accent-primary)] opacity-30"></div>
      <div class="absolute bottom-0 left-1/2 w-1 h-1 -translate-x-1/2 rounded-full bg-[var(--color-accent-primary)] opacity-20"></div>
      <div class="absolute left-0 top-1/2 w-1 h-1 -translate-y-1/2 rounded-full bg-[var(--color-text-primary)] opacity-15"></div>
    </div>
  </div>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 md:px-12">
    <!-- Status badge (clickable) -->
    <a href="/contact" class="mb-8 inline-flex items-center gap-3 hero-initial-hidden group" data-hero-badge>
      <span class="relative flex h-2.5 w-2.5">
        <span class="absolute inline-flex h-full w-full rounded-full bg-[var(--color-employment-primary)] opacity-75 animate-ping"></span>
        <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-[var(--color-employment-primary)]"></span>
      </span>
      <span class="text-sm text-theme-muted font-mono tracking-wide group-hover:text-theme-accent transition-colors duration-200">
        {site.employment.message[site.employment.status]}
      </span>
    </a>

    <!-- Name -->
    <h1 class="leading-[0.85] tracking-[-0.02em] md:tracking-[-0.04em] font-display font-[800] w-full overflow-visible" style="font-size: clamp(2.5rem, 11vw, 10rem);">
      <span
        class="block hero-name-shimmer hero-initial-hidden"
        aria-label={firstName}
        data-hero-firstname
      >{firstName}</span>
      <span
        class="block hero-name-shimmer hero-initial-hidden"
        aria-label={lastName}
        data-hero-lastname
      >{lastName}</span>
    </h1>

    <!-- Pulsing amber line -->
    <div class="my-6 md:my-8 h-[2px] w-24 md:w-32 bg-[var(--color-accent-primary)] rounded-full hero-initial-hidden" style="animation: pulse-line 3s ease-in-out infinite;" aria-hidden="true" data-hero-line></div>

    <!-- Role rotator -->
    <div class="h-8 overflow-hidden mb-6 hero-initial-hidden" data-hero-role>
      <span
        class="inline-block font-mono text-sm md:text-base text-theme-accent tracking-wider uppercase transition-all duration-300 ease-out"
        data-role-rotator
        data-roles={JSON.stringify(roles)}
      >
        {roles[0]}
      </span>
    </div>

    <!-- Summary -->
    <p class="max-w-xl text-base md:text-lg text-theme-secondary leading-relaxed hero-initial-hidden" data-hero-summary>
      {site.summary}
    </p>
  </div>

  <!-- Scroll indicator — page-centered, outside content container -->
  <div class="absolute bottom-8 inset-x-0 mx-auto w-fit flex flex-col items-center gap-2 hero-initial-hidden" data-hero-scroll>
    <span class="text-xs text-theme-muted font-mono tracking-widest uppercase">Explore my work</span>
    <div class="w-[1px] h-8 bg-gradient-to-b from-[var(--color-accent-primary)] to-transparent" style="animation: scroll-bob 2s ease-in-out infinite;"></div>
  </div>

</section>

<style>
  .hero-name-shimmer {
    background: linear-gradient(90deg, var(--color-accent-primary), var(--color-text-primary), rgb(190 100 60), var(--color-accent-primary));
    background-size: 300% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    padding-right: 0.05em;
    animation: shimmer 6s linear infinite;
  }

  /* Initial hidden state — GSAP entrance reveals these; auto-visible for reduced-motion */
  .hero-initial-hidden {
    opacity: 0;
  }

  @keyframes shimmer {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  .hero-glow-layer {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(212,160,48,0.12), transparent 55%),
      radial-gradient(ellipse at 80% 20%, rgba(190,100,60,0.07), transparent 55%),
      radial-gradient(ellipse at 50% 80%, rgba(212,160,48,0.06), transparent 55%);
    background-size: 160% 160%;
    animation: gradient-shift 12s ease-in-out infinite;
    mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 85%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 60%, transparent 85%);
  }

  [data-theme="light"] .hero-glow-layer {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(184,136,42,0.07), transparent 55%),
      radial-gradient(ellipse at 80% 20%, rgba(160,90,40,0.05), transparent 55%),
      radial-gradient(ellipse at 50% 80%, rgba(184,136,42,0.04), transparent 55%);
    background-size: 160% 160%;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @keyframes orbit-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes pulse-line {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(6px); opacity: 0.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-name-shimmer { animation: none; }
    .hero-initial-hidden { opacity: 1; }
    .hero-glow-layer,
    [style*="animation: gradient-shift"],
    [style*="animation: orbit-spin"],
    [style*="animation: pulse-line"],
    [style*="animation: scroll-bob"] {
      animation: none !important;
    }
  }
</style>

<script>
  import { initHeroAnimations } from '../scripts/hero-animations';

  // Cinematic entrance + scroll-linked exit
  initHeroAnimations();

  // Role rotator (independent interval, stays as-is)
  const rotator = document.querySelector('[data-role-rotator]');
  if (rotator && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const rolesAttr = rotator.getAttribute('data-roles');
    if (rolesAttr) {
      const roles = JSON.parse(rolesAttr) as string[];
      let index = 0;
      setInterval(() => {
        index = (index + 1) % roles.length;
        (rotator as HTMLElement).style.transform = 'translateY(100%)';
        (rotator as HTMLElement).style.opacity = '0';
        setTimeout(() => {
          rotator.textContent = roles[index];
          (rotator as HTMLElement).style.transform = 'translateY(0)';
          (rotator as HTMLElement).style.opacity = '1';
        }, 300);
      }, 3200);
    }
  }
</script>
