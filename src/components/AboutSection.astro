---
import site from "../config/site";
import { gravatarUrl } from "../lib/gravatar";
import { experience, education, certifications, skillCategories, spokenLanguages } from "../config/resume";

const aboutParagraphs = site.about.trim().split('\n\n').map(p => p.trim()).filter(Boolean);

// Terminal config
const user = 'ezra';
const host = 'hulsman';
const prompt = `${user}@${host}`;

// Animation commands — the full set
const terminalLines: { type: 'cmd' | 'out' | 'blank'; text: string }[] = [
  { type: 'cmd', text: 'whoami' },
  { type: 'out', text: user },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'hostname -f' },
  { type: 'out', text: 'hulsman.dev' },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'cat /etc/role' },
  { type: 'out', text: `${site.role} @ ${site.company}` },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'uptime -p' },
  { type: 'out', text: 'up 3 years, 0 unplanned restarts' },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'cat /proc/height' },
  { type: 'out', text: '2.00m — good overview of server racks' },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'neofetch --location' },
  { type: 'out', text: site.location },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'echo $STACK | tr ":" "\\n"' },
  { type: 'out', text: site.skills.languages.join(' · ') },
  { type: 'out', text: site.skills.tools.join(' · ') },
];

// Data for interactive terminal (serialized to JSON for client-side)
const terminalData = {
  prompt,
  site: {
    name: site.name,
    role: site.role,
    company: site.company,
    location: site.location,
    skills: site.skills,
    social: { email: site.social.email, GitHub: site.social.GitHub, LinkedIn: site.social.LinkedIn },
    employment: site.employment,
  },
  projects: site.projects.map(p => ({
    title: p.title,
    description: p.description,
    tech: p.tech,
    github: p.github || '',
    link: p.link || '',
    slug: (p.link || '').replace('/projects/', ''),
  })),
  experience: experience.map(e => ({ role: e.role, client: e.client, startDate: e.startDate, endDate: e.endDate || '', summary: e.summary, group: e.group })),
  education: education.map(e => ({ degree: e.degree, institution: e.institution, startYear: e.startYear, endYear: e.endYear, gpa: e.gpa || '', result: e.result || '' })),
  certifications: certifications.map(c => ({ name: c.name, institution: c.institution, year: c.year, credential: c.credential || '' })),
  skills: skillCategories.map(s => ({ label: s.label, items: s.items })),
};
---

<section id="about" class="relative py-24 md:py-32">
  <div class="mx-auto w-full max-w-7xl px-6 md:px-12">
    <!-- Section label -->
    <div class="mb-16" data-reveal>
      <span class="font-mono text-xs tracking-[0.3em] uppercase text-theme-accent">// About</span>
      <h2 class="mt-2 font-display text-3xl md:text-5xl font-bold text-theme-primary tracking-tight">
        Who I am
      </h2>
    </div>

    <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">
      <!-- Left column: photo + bio -->
      <div class="lg:col-span-3 space-y-8">
        <div class="flex flex-col sm:flex-row items-start gap-6" data-reveal>
          <img
            src={gravatarUrl}
            alt={`${site.name} profile photo`}
            width="200"
            height="200"
            loading="lazy"
            class="rounded-full border-2 border-[var(--color-accent-border)] w-[150px] h-[150px] md:w-[200px] md:h-[200px] shrink-0"
            style="filter: brightness(0.95) contrast(1.05) saturate(1.1);"
          />
          <div class="space-y-4">
            {aboutParagraphs.map(p => (
              <p class="text-base text-theme-secondary leading-relaxed">{p}</p>
            ))}
          </div>
        </div>

        <!-- Interest tags -->
        <div class="flex flex-wrap gap-2" data-reveal>
          {site.interests.map(interest => (
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border border-[var(--color-accent-border)] bg-[var(--color-accent-alpha)] text-theme-accent">
              {interest}
            </span>
          ))}
        </div>
      </div>

      <!-- Right column: terminal card -->
      <div class="lg:col-span-2" data-reveal>
        <div class="rounded-xl border border-[var(--color-border-primary)] bg-[var(--color-bg-secondary)] overflow-hidden shadow-lg relative">
          <!-- macOS title bar -->
          <div class="flex items-center gap-2 px-4 py-2.5 border-b border-[var(--color-border-primary)] bg-[var(--color-bg-primary)]">
            <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
            <span id="terminal-title" class="flex-1 text-center text-[11px] text-theme-muted font-mono -ml-10">{prompt} — zsh — 80×24</span>
          </div>

          <!-- Terminal body -->
          <div
            id="terminal-body"
            class="p-4 font-mono text-[13px] leading-[1.6] bg-[var(--color-bg-primary)] min-h-[280px] max-h-[400px] overflow-y-auto relative cursor-text"
            role="application"
            aria-label="Interactive terminal"
            tabindex="0"
            data-prompt={prompt}
            data-lines={JSON.stringify(terminalLines)}
          >
            <noscript>
              {terminalLines.map(line => (
                line.type === 'blank' ? (
                  <div class="h-1"></div>
                ) : line.type === 'cmd' ? (
                  <div>
                    <span class="text-[rgb(120,165,145)]">{prompt}</span>
                    <span class="text-theme-muted">:</span>
                    <span class="text-[rgb(140,145,80)]">~</span>
                    <span class="text-theme-primary"> $ {line.text}</span>
                  </div>
                ) : (
                  <div class="text-theme-secondary">{line.text}</div>
                )
              ))}
            </noscript>
          </div>

          <!-- Hidden input + hint are created by interactive-terminal.ts -->
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Terminal data for interactive mode -->
<script type="application/json" id="terminal-data" set:html={JSON.stringify(terminalData)}></script>

<style>
  .terminal-cursor {
    display: inline-block;
    min-width: 8px;
    height: 1.1em;
    background-color: var(--color-accent-primary);
    color: var(--color-bg-primary);
    vertical-align: text-bottom;
    animation: terminal-blink 1s step-end infinite;
  }
  .terminal-cursor.typing {
    animation: none;
    opacity: 1;
  }
  /* Interactive terminal input line */
  .terminal-input-line {
    white-space: pre-wrap;
    word-break: break-all;
  }
  .terminal-prompt {
    white-space: nowrap;
  }

  @keyframes terminal-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Neofetch output */
  .neofetch-output {
    white-space: pre;
    line-height: 1.2;
    font-size: 12px;
  }
  .neofetch-label {
    color: var(--color-accent-primary);
    font-weight: bold;
  }

  /* Cowsay */
  .cowsay-output {
    white-space: pre;
    line-height: 1.3;
  }

  /* Matrix / SL */
  .matrix-container {
    position: relative;
    overflow: hidden;
    height: 200px;
  }
  .matrix-char {
    position: absolute;
    color: #00ff00;
    font-size: 13px;
    opacity: 0.8;
  }

  /* Interactive terminal text colors */
  .terminal-accent { color: var(--color-accent-primary); font-weight: bold; }
  .terminal-cmd { color: var(--color-text-primary); }
  .terminal-dim { color: var(--color-text-muted); }
  .terminal-error { color: rgb(239 68 68); }
  .terminal-success { color: rgb(34 197 94); }

  /* Terminal scrollbar */
  #terminal-body::-webkit-scrollbar { width: 6px; }
  #terminal-body::-webkit-scrollbar-track { background: transparent; }
  #terminal-body::-webkit-scrollbar-thumb { background: var(--color-border-primary); border-radius: 3px; }

  @media (prefers-reduced-motion: reduce) {
    .terminal-cursor { animation: none; }
  }
</style>

<script>
  import { initTerminalAnimation } from '../scripts/terminal-animation';
  import { InteractiveTerminal } from '../scripts/interactive-terminal';

  const body = document.getElementById('terminal-body');
  if (body) {
    // Parse terminal data
    const dataEl = document.getElementById('terminal-data');
    const terminalData = dataEl ? JSON.parse(dataEl.textContent || '{}') : {};

    // Create interactive terminal (waits for activation)
    const terminal = new InteractiveTerminal(body, terminalData);

    // Listen for animation completion
    body.addEventListener('terminal-animation-complete', () => {
      terminal.activate();
    }, { once: true });

    // Start the typing animation
    initTerminalAnimation(body);
  }
</script>
