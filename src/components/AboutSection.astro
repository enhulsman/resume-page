---
import site from "../config/site";
import { gravatarUrl } from "../lib/gravatar";

const aboutParagraphs = site.about.trim().split('\n\n').map(p => p.trim()).filter(Boolean);

// Terminal lines — realistic prompt with hostname
const user = 'ezra';
const host = 'hulsman';
const prompt = `${user}@${host}`;

const terminalLines: { type: 'cmd' | 'out' | 'blank'; text: string }[] = [
  { type: 'cmd', text: 'whoami' },
  { type: 'out', text: user },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'hostname -f' },
  { type: 'out', text: 'hulsman.dev' },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'cat /etc/role' },
  { type: 'out', text: `${site.role} @ ${site.company}` },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'uptime -p' },
  { type: 'out', text: 'up 3 years, 0 unplanned restarts' },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'cat /proc/height' },
  { type: 'out', text: '2.00m — good overview of server racks' },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'neofetch --location' },
  { type: 'out', text: site.location },
  { type: 'blank', text: '' },
  { type: 'cmd', text: 'echo $STACK | tr ":" "\\n"' },
  { type: 'out', text: site.skills.languages.join(' · ') },
  { type: 'out', text: site.skills.tools.join(' · ') },
];
---

<section id="about" class="relative py-24 md:py-32">
  <div class="mx-auto w-full max-w-7xl px-6 md:px-12">
    <!-- Section label -->
    <div class="mb-16" data-reveal>
      <span class="font-mono text-xs tracking-[0.3em] uppercase text-theme-accent">// About</span>
      <h2 class="mt-2 font-display text-3xl md:text-5xl font-bold text-theme-primary tracking-tight">
        Who I am
      </h2>
    </div>

    <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">
      <!-- Left column: photo + bio -->
      <div class="lg:col-span-3 space-y-8">
        <div class="flex flex-col sm:flex-row items-start gap-6" data-reveal>
          <!-- Photo -->
          <img
            src={gravatarUrl}
            alt={`${site.name} profile photo`}
            width="200"
            height="200"
            loading="lazy"
            class="rounded-full border-2 border-[var(--color-accent-border)] w-[150px] h-[150px] md:w-[200px] md:h-[200px] shrink-0"
            style="filter: brightness(0.95) contrast(1.05) saturate(1.1);"
          />
          <div class="space-y-4">
            {aboutParagraphs.map(p => (
              <p class="text-base text-theme-secondary leading-relaxed">{p}</p>
            ))}
          </div>
        </div>

        <!-- Interest tags -->
        <div class="flex flex-wrap gap-2" data-reveal>
          {site.interests.map(interest => (
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border border-[var(--color-accent-border)] bg-[var(--color-accent-alpha)] text-theme-accent">
              {interest}
            </span>
          ))}
        </div>
      </div>

      <!-- Right column: terminal card -->
      <div class="lg:col-span-2" data-reveal>
        <div class="rounded-xl border border-[var(--color-border-primary)] bg-[var(--color-bg-secondary)] overflow-hidden shadow-lg">
          <!-- macOS title bar -->
          <div class="flex items-center gap-2 px-4 py-2.5 border-b border-[var(--color-border-primary)] bg-[var(--color-bg-primary)]">
            <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
            <span class="flex-1 text-center text-[11px] text-theme-muted font-mono -ml-10">{prompt} — zsh — 80×24</span>
          </div>

          <!-- Terminal body — JS animates typing, SSR shows final state as fallback -->
          <div
            id="terminal-body"
            class="p-4 font-mono text-[13px] leading-[1.6] bg-[var(--color-bg-primary)] min-h-[280px]"
            data-prompt={prompt}
            data-lines={JSON.stringify(terminalLines)}
          >
            <!-- SSR fallback: full terminal shown if JS doesn't run -->
            <noscript>
              {terminalLines.map(line => (
                line.type === 'blank' ? (
                  <div class="h-1"></div>
                ) : line.type === 'cmd' ? (
                  <div>
                    <span class="text-[rgb(120,165,145)]">{prompt}</span>
                    <span class="text-theme-muted">:</span>
                    <span class="text-[rgb(140,145,80)]">~</span>
                    <span class="text-theme-primary"> $ {line.text}</span>
                  </div>
                ) : (
                  <div class="text-theme-secondary">{line.text}</div>
                )
              ))}
            </noscript>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .terminal-cursor {
    display: inline-block;
    width: 8px;
    height: 1.1em;
    background-color: var(--color-accent-primary);
    vertical-align: text-bottom;
    animation: terminal-blink 1s step-end infinite;
  }
  .terminal-cursor.typing {
    animation: none;
    opacity: 1;
  }

  @keyframes terminal-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-cursor { animation: none; }
  }
</style>

<script>
  // Terminal typing animation
  (function() {
    const body = document.getElementById('terminal-body');
    if (!body) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const promptStr = body.getAttribute('data-prompt') || 'user@host';
    const lines = JSON.parse(body.getAttribute('data-lines') || '[]');

    // Build prompt HTML
    function makePrompt() {
      return `<span style="color:rgb(120,165,145)">${promptStr}</span>` +
             `<span class="text-theme-muted">:</span>` +
             `<span style="color:rgb(140,145,80)">~</span>` +
             `<span class="text-theme-primary"> $ </span>`;
    }

    function makeCursor(typing) {
      return `<span class="terminal-cursor${typing ? ' typing' : ''}">&#8203;</span>`;
    }

    // Group lines into commands: { cmd: string, output: string[] }
    const commands = [];
    let current = null;
    for (const line of lines) {
      if (line.type === 'cmd') {
        if (current) commands.push(current);
        current = { cmd: line.text, output: [] };
      } else if (line.type === 'out' && current) {
        current.output.push(line.text);
      }
    }
    if (current) commands.push(current);

    // If reduced motion, show everything instantly
    if (prefersReduced) {
      let html = '';
      for (const cmd of commands) {
        html += `<div>${makePrompt()}<span class="text-theme-primary">${cmd.cmd}</span></div>`;
        for (const out of cmd.output) {
          html += `<div class="text-theme-secondary">${out}</div>`;
        }
        html += '<div class="h-1"></div>';
      }
      html += `<div>${makePrompt()}${makeCursor(false)}</div>`;
      body.innerHTML = html;
      return;
    }

    // Animate: type each command char by char, then instantly show output
    body.innerHTML = '';
    let cmdIndex = 0;

    // Use IntersectionObserver to start animation when visible
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        observer.disconnect();
        startTyping();
      }
    }, { threshold: 0.3 });
    observer.observe(body);

    function startTyping() {
      typeNextCommand();
    }

    function typeNextCommand() {
      if (cmdIndex >= commands.length) {
        // All done — show final prompt with blinking cursor
        appendHTML(`<div>${makePrompt()}${makeCursor(false)}</div>`);
        return;
      }

      const cmd = commands[cmdIndex];

      // Create the prompt line with cursor
      const lineEl = document.createElement('div');
      lineEl.innerHTML = makePrompt() + makeCursor(true);
      body.appendChild(lineEl);
      scrollToBottom();

      // Type command characters one by one
      let charIdx = 0;
      const typingSpeed = 40 + Math.random() * 30; // 40-70ms per char

      function typeChar() {
        if (charIdx < cmd.cmd.length) {
          // Replace cursor with typed text + cursor
          const typed = escapeHtml(cmd.cmd.substring(0, charIdx + 1));
          lineEl.innerHTML = makePrompt() +
            `<span class="text-theme-primary">${typed}</span>` +
            makeCursor(true);
          charIdx++;
          scrollToBottom();

          // Vary speed slightly for realism
          const delay = typingSpeed + (Math.random() - 0.5) * 30;
          setTimeout(typeChar, delay);
        } else {
          // Command fully typed — remove cursor from this line
          lineEl.innerHTML = makePrompt() +
            `<span class="text-theme-primary">${escapeHtml(cmd.cmd)}</span>`;

          // Brief pause then show output instantly
          setTimeout(() => {
            for (const out of cmd.output) {
              appendHTML(`<div class="text-theme-secondary">${escapeHtml(out)}</div>`);
            }
            appendHTML('<div class="h-1"></div>');
            scrollToBottom();

            cmdIndex++;
            // Pause before next command
            setTimeout(typeNextCommand, 300 + Math.random() * 200);
          }, 80);
        }
      }

      // Small delay before starting to type (like thinking)
      setTimeout(typeChar, 200 + Math.random() * 300);
    }

    function appendHTML(html) {
      const el = document.createElement('div');
      el.innerHTML = html;
      while (el.firstChild) body.appendChild(el.firstChild);
    }

    function scrollToBottom() {
      body.scrollTop = body.scrollHeight;
    }

    function escapeHtml(str) {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
  })();
</script>
