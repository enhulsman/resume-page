---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillsGrid from '../components/resume/SkillsGrid.astro';
import ExperienceTimeline from '../components/resume/ExperienceTimeline.astro';
import EducationList from '../components/resume/EducationList.astro';
import CertificationList from '../components/resume/CertificationList.astro';
import site from '../config/site';
import IconEmail from '../components/icons/IconEmail.astro';
import IconGitHub from '../components/icons/IconGitHub.astro';
import IconLinkedIn from '../components/icons/IconLinkedIn.astro';
---

<BaseLayout
  title={`Resume — ${site.name}`}
  description={`Professional resume of ${site.name}. ${site.role} at ${site.company}, based in ${site.location}.`}
  keywords={`${site.seo.keywords}, resume, CV, work experience, certifications`}
  ogTitle={`Resume — ${site.name}`}
  ogDescription={`${site.role} at ${site.company}. Work experience, skills, education, and certifications.`}
>
  <!-- Compact profile header — makes this page standalone for recruiters -->
  <div class="mb-10 rounded-xl border border-[var(--color-border-primary)] bg-[var(--color-bg-secondary)] p-5 md:p-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="font-display text-2xl md:text-3xl font-bold tracking-tight text-theme-primary">
          {site.name}
        </h1>
        <p class="mt-1 text-sm text-theme-secondary">
          {site.role} at <a href={site.social.employer} target="_blank" rel="noopener noreferrer" class="text-theme-accent hover:underline">{site.company}</a> · {site.location}
        </p>
        <p class="mt-2 text-sm text-theme-muted max-w-xl">
          {site.summary}
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 text-sm font-medium font-display px-4 py-2 rounded-lg border border-[var(--color-accent-border)] text-theme-accent bg-[var(--color-accent-alpha)] hover:bg-[var(--color-accent-primary)] hover:text-[var(--color-bg-primary)] transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Inquire about my full CV
          </a>
          <a
            href={`mailto:${site.social.email}`}
            class="inline-flex items-center gap-2 text-sm font-medium font-display px-4 py-2 rounded-lg border border-[var(--color-border-primary)] text-theme-secondary hover:text-theme-accent hover:border-[var(--color-accent-border)] transition-all duration-200"
          >
            Get in touch
          </a>
        </div>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        <a href={`mailto:${site.social.email}`} class="flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--color-border-primary)] text-theme-muted hover:text-theme-accent hover:border-[var(--color-accent-border)] transition-colors" aria-label="Email" title="Email">
          <IconEmail />
        </a>
        <a href={site.social.GitHub} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--color-border-primary)] text-theme-muted hover:text-theme-accent hover:border-[var(--color-accent-border)] transition-colors" aria-label="GitHub" title="GitHub">
          <IconGitHub />
        </a>
        <a href={site.social.LinkedIn} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-9 h-9 rounded-lg border border-[var(--color-border-primary)] text-theme-muted hover:text-theme-accent hover:border-[var(--color-accent-border)] transition-colors" aria-label="LinkedIn" title="LinkedIn">
          <IconLinkedIn />
        </a>
      </div>
    </div>
  </div>

  <section class="mb-10">
    <h2 class="font-display text-xl font-bold tracking-tight text-theme-primary mb-4 flex items-center gap-3">
      <span class="w-6 h-px bg-[var(--color-accent-primary)]" aria-hidden="true"></span>
      Skills
    </h2>
    <div class="rounded-xl border border-[var(--color-border-primary)] bg-[var(--color-bg-secondary)] p-5 md:p-6">
      <SkillsGrid />
    </div>
  </section>

  <section class="mb-10">
    <h2 class="font-display text-xl font-bold tracking-tight text-theme-primary mb-4 flex items-center gap-3">
      <span class="w-6 h-px bg-[var(--color-accent-primary)]" aria-hidden="true"></span>
      Experience
    </h2>
    <div class="rounded-xl border border-[var(--color-border-primary)] bg-[var(--color-bg-secondary)] p-5 md:p-6">
      <ExperienceTimeline />
    </div>
  </section>

  <section class="mb-10">
    <h2 class="font-display text-xl font-bold tracking-tight text-theme-primary mb-4 flex items-center gap-3">
      <span class="w-6 h-px bg-[var(--color-accent-primary)]" aria-hidden="true"></span>
      Education
    </h2>
    <div class="rounded-xl border border-[var(--color-border-primary)] bg-[var(--color-bg-secondary)] p-5 md:p-6">
      <EducationList />
    </div>
  </section>

  <section class="mb-10">
    <h2 class="font-display text-xl font-bold tracking-tight text-theme-primary mb-4 flex items-center gap-3">
      <span class="w-6 h-px bg-[var(--color-accent-primary)]" aria-hidden="true"></span>
      Certifications
    </h2>
    <div class="rounded-xl border border-[var(--color-border-primary)] bg-[var(--color-bg-secondary)] p-5 md:p-6">
      <CertificationList />
    </div>
  </section>
</BaseLayout>
