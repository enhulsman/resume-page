---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import AboutSection from "../components/AboutSection.astro";
import ProjectsShowcase from "../components/ProjectsShowcase.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import ContactCTA from "../components/ContactCTA.astro";
import site from "../config/site";

const homeDescription = `${site.summary} Based in ${site.location}, specializing in ${site.skills.languages.join(", ")} and ${site.skills.tools.join(", ")}.`;
const homeKeywords = `${site.seo.keywords}, resume, portfolio, ${site.location}, ${site.company}`;
---

<BaseLayout
  title={`${site.name} — ${site.role}`}
  description={homeDescription}
  keywords={homeKeywords}
  ogTitle={`${site.name} — ${site.role} Portfolio & Resume`}
  ogDescription={homeDescription}
  fullWidth
>
  <HeroSection />
  <AboutSection />
  <ProjectsShowcase />
  <ExperienceSection />
  <SkillsSection />
  <ContactCTA />

  <!-- GSAP ScrollTrigger for scroll reveals -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      document.querySelectorAll('[data-reveal]').forEach((el) => {
        gsap.set(el, { opacity: 0, y: 40 });
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            once: true,
          },
        });
      });
    }
  </script>
</BaseLayout>
