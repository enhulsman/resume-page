---
import site from "../config/site";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Metadata, { type MetadataProps } from "../components/Metadata.astro";
import "../styles/global.css";

export interface Props extends MetadataProps {
  title?: string;
  description?: string;
  fullWidth?: boolean;
}

const { title, description, fullWidth = false, ...metadataProps } = Astro.props;
---

<!doctype html>
<html lang="en" class="min-h-full">
  <head>
    <Metadata title={title} description={description} {...metadataProps} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const theme = stored || "dark";
        if (theme !== "dark") document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body
    class="font-sans min-h-screen bg-[var(--color-bg-primary)] text-[var(--color-text-secondary)]"
  >
    <!-- Dot grid -->
    <div class="pointer-events-none fixed inset-0 z-0" aria-hidden="true"
      style="background-image: radial-gradient(rgba(240, 234, 214, 0.05) 1px, transparent 1px); background-size: 40px 40px;">
    </div>

    <!-- Floating elements -->
    <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden="true">
      <div class="rounded-full absolute" style="width:20px;height:20px;left:8%;top:15%;background:rgb(201 148 43);opacity:0.08;animation:float 5s ease-in-out infinite;"></div>
      <div class="rounded-sm absolute" style="width:16px;height:16px;left:88%;top:30%;background:rgb(201 148 43);opacity:0.1;animation:float 6s ease-in-out 1s infinite;"></div>
      <div class="rounded-full absolute" style="width:24px;height:24px;left:72%;top:52%;background:rgb(201 148 43);opacity:0.06;animation:float 7s ease-in-out 2s infinite;"></div>
      <div class="rounded-full absolute" style="width:14px;height:14px;left:15%;top:62%;background:rgb(201 148 43);opacity:0.09;animation:float 5.5s ease-in-out 0.5s infinite;"></div>
      <div class="rounded-full absolute" style="width:18px;height:18px;left:55%;top:12%;background:rgb(201 148 43);opacity:0.07;animation:float 6.5s ease-in-out 3s infinite;"></div>
    </div>

    <Nav />
    <main class={fullWidth ? "min-h-[70vh] relative z-10" : "min-h-[70vh] mx-auto max-w-6xl px-3 sm:px-6 py-6 sm:py-8 pt-24 relative z-10"}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
