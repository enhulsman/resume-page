---
import site from "../config/site";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import DotGrid from "../components/DotGrid.astro";
import Metadata, { type MetadataProps } from "../components/Metadata.astro";
import "../styles/global.css";

export interface Props extends MetadataProps {
  title?: string;
  description?: string;
  fullWidth?: boolean;
}

const { title, description, fullWidth = false, ...metadataProps } = Astro.props;
---

<!doctype html>
<html lang="en" class="min-h-full">
  <head>
    <Metadata title={title} description={description} {...metadataProps} />

    <link rel="preload" href="/fonts/syne-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const theme = stored || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        if (theme !== "dark") document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <script>
      import '../scripts/smooth-scroll';
    </script>
  </head>
  <body
    class="relative font-sans min-h-screen bg-[var(--color-bg-primary)] text-[var(--color-text-secondary)]"
  >
    <DotGrid hasHero={fullWidth} />
    <Nav />
    <main class={fullWidth ? "min-h-[70vh] relative" : "min-h-[70vh] mx-auto max-w-6xl px-3 sm:px-6 pb-6 sm:pb-8 pt-20 sm:pt-24 md:pt-28 relative"}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
